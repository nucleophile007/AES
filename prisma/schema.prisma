generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WebinarRegistration {
  id            Int      @id @default(autoincrement())
  email         String
  parentName    String
  parentEmail   String
  parentPhone   String
  studentName   String
  grade         String
  schoolName    String
  program       String
  preferredTime String
  createdAt     DateTime @default(now())
  approved      Boolean  @default(false)
  adminEmail    String?
}

model AvailabilityDay {
  id         Int      @id @default(autoincrement())
  date       String
  times      Json
  adminEmail String   @default("acharya.folsom@gmail.com")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  timesUTC   Json?
  timezone   String?

  @@unique([date, adminEmail])
}

model Teacher {
  id                      Int                       @id @default(autoincrement())
  name                    String
  email                   String                    @unique
  password                String?
  programs                String[]
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  isActivated             Boolean                   @default(false)
  googleAccessToken       String?
  googleCalendarConnected Boolean                   @default(false)
  googleRefreshToken      String?
  googleTokenExpiry       DateTime?
  assignments             Assignment[]
  classSchedules          ClassSchedule[]
  mentorProfile           Mentor?
  progressReports         ProgressReport[]
  resources               Resource[]
  studentGroups           StudentGroup[]
  submissionRemarks       StudentSubmissionRemark[]
  students                TeacherStudent[]
}

model Student {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  password            String?
  grade               String
  schoolName          String
  parentName          String
  parentEmail         String
  parentPhone         String
  program             String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isActivated         Boolean              @default(false)
  parentAccountId     Int?
  graduationYear      Int?
  assignedAssignments Assignment[]         @relation("AssignedAssignments")
  Blog                Blog[]
  classSchedules      ClassSchedule[]
  enrollments         Enrollment[]
  Payment             Payment[]
  progressReports     ProgressReport[]
  Research            Research[]
  parentAccount       ParentAccount?       @relation(fields: [parentAccountId], references: [id])
  groupMemberships    StudentGroupMember[]
  assignedResources   StudentResource[]
  studentSubmissions  StudentSubmission[]
  submissions         Submission[]
  teacherLinks        TeacherStudent[]
  Testimonial         Testimonial[]
}

model TeacherStudent {
  id         Int      @id @default(autoincrement())
  teacherId  Int
  studentId  Int
  program    String
  assignedAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId, program])
}

model StudentGroup {
  id             Int                  @id @default(autoincrement())
  name           String
  teacherId      Int
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  classSchedules ClassSchedule[]
  teacher        Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  members        StudentGroupMember[]

  @@unique([teacherId, name])
}

model StudentGroupMember {
  id         Int          @id @default(autoincrement())
  groupId    Int
  studentId  Int
  assignedAt DateTime     @default(now())
  group      StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student    Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
}

model Assignment {
  id                  Int                  @id @default(autoincrement())
  title               String
  description         String
  instructions        String?
  program             String
  subject             String
  dueDate             DateTime
  totalPoints         Int                  @default(100)
  isActive            Boolean              @default(true)
  allowLateSubmission Boolean              @default(false)
  teacherId           Int                  @default(1)
  targetStudentId     Int?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  dueDateTimezone     String?
  targetStudent       Student?             @relation("AssignedAssignments", fields: [targetStudentId], references: [id])
  teacher             Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  resources           AssignmentResource[]
  submissions         Submission[]
}

model Submission {
  id               Int        @id @default(autoincrement())
  studentId        Int
  assignmentId     Int
  content          String?
  fileUrl          String?
  fileName         String?
  fileSize         Int?
  submittedAt      DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt
  grade            Int?
  feedback         String?
  status           String     @default("submitted")
  submissionNumber Int        @default(1)
  assignment       Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student          Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
}

model Enrollment {
  id        Int       @id @default(autoincrement())
  studentId Int
  program   String
  subject   String
  startDate DateTime  @default(now())
  isActive  Boolean   @default(true)
  access    String    @default("unblocked")
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Payment   Payment[]

  @@unique([studentId, program, subject])
}

model Resource {
  id                 Int                  @id @default(autoincrement())
  title              String
  description        String?
  type               String
  fileUrl            String?
  linkUrl            String?
  fileName           String?
  fileSize           Int?
  program            String
  subject            String
  grade              String
  teacherId          Int
  isPublic           Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  assignmentLinks    AssignmentResource[]
  teacher            Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentAssignments StudentResource[]
}

model AssignmentResource {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  resourceId   Int
  isRequired   Boolean    @default(false)
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  resource     Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, resourceId])
}

model StudentResource {
  id         Int       @id @default(autoincrement())
  studentId  Int
  resourceId Int
  assignedAt DateTime  @default(now())
  viewedAt   DateTime?
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, resourceId])
}

model StudentSubmission {
  id             Int                       @id @default(autoincrement())
  studentId      Int
  title          String
  description    String?
  content        String?
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  submittedAt    DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  teacherIds     Int[]
  student        Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherRemarks StudentSubmissionRemark[]
}

model StudentSubmissionRemark {
  id                  Int               @id @default(autoincrement())
  studentSubmissionId Int
  teacherId           Int
  remark              String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  studentSubmission   StudentSubmission @relation(fields: [studentSubmissionId], references: [id], onDelete: Cascade)
  teacher             Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([studentSubmissionId, teacherId])
}

model Message {
  id            String    @id @default(uuid())
  senderId      Int
  senderRole    String
  recipientId   Int
  recipientRole String
  content       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isRead        Boolean   @default(false)
  readAt        DateTime?

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, isRead])
  @@index([createdAt(sort: Desc)])
}

model ClassSchedule {
  id                    Int           @id @default(autoincrement())
  title                 String
  date                  DateTime
  startTime             String
  endTime               String
  subject               String
  description           String?
  location              String?
  meetingLink           String?
  status                String        @default("upcoming")
  color                 String?
  studentId             Int
  teacherId             Int
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  endDateTime           DateTime?
  googleCalendarEventId String?
  groupId               Int?
  meetingMinutes        String?
  reminderJobId         String?
  reminderScheduledFor  DateTime?
  reminderSentAt        DateTime?
  startDateTime         DateTime?
  timezone              String?
  group                 StudentGroup? @relation(fields: [groupId], references: [id])
  student               Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher               Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@index([startDateTime, reminderSentAt])
  @@index([reminderJobId])
}

model ActivationRequest {
  id        Int      @id @default(autoincrement())
  email     String
  role      String
  token     String   @unique
  userId    Int
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, role])
}

model PasswordResetRequest {
  id        Int      @id @default(autoincrement())
  role      String
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, userId])
  @@index([expiresAt])
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Payment {
  id              Int        @id @default(autoincrement())
  enrollmentId    Int
  studentId       Int
  studentEmail    String
  studentName     String
  parentName      String
  parentEmail     String
  parentPhone     String
  program         String
  subject         String
  paymentInfo     String
  amount          String?
  dueDate         String
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  status          String     @default("pending")
  sentAt          DateTime   @default(now())
  paidAt          DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime
  dueDateTimezone String?
  dueDateUTC      DateTime?
  Enrollment      Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  Student         Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id                    Int       @id @default(autoincrement())
  studentId             Int?
  content               String?
  authorType            String?
  authorName            String?
  isApproved            Boolean   @default(false)
  isVisible             Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  videoLink             String?
  beforeAfterApproved   Boolean   @default(false)
  consentToFeature      Boolean   @default(false)
  contentApproved       Boolean   @default(false)
  experienceDescription String?
  grade                 String?
  programs              String[]
  programsApproved      Boolean   @default(false)
  rating                Int?
  ratingApproved        Boolean   @default(false)
  school                String?
  studentInfo           String?
  studentName           String?
  submittedAt           DateTime?
  successStory          String?
  successStoryApproved  Boolean   @default(false)
  afterChanges          String?
  beforeExpectations    String?
  Student               Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model SecurityLog {
  id        Int      @id @default(autoincrement())
  event     String
  userId    Int
  userRole  String
  success   Boolean
  ipAddress String
  userAgent String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, event])
  @@index([createdAt])
}

model FailedActivation {
  id        Int      @id @default(autoincrement())
  token     String
  ipAddress String
  userAgent String
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([ipAddress])
  @@index([createdAt])
}

model Feedback {
  id                        Int       @id @default(autoincrement())
  parentId                  Int?
  parentName                String?
  parentEmail               String?
  status                    String    @default("new")
  response                  String?
  createdAt                 DateTime  @default(now())
  reviewedAt                DateTime?
  beforeAfterApproved       Boolean   @default(false)
  beforeAfterExpectations   String?
  childExperience           String?
  childExperienceApproved   Boolean   @default(false)
  consentToFeature          Boolean   @default(false)
  favoriteThingToShare      String?
  grade                     String?
  heardAbout                String?
  isApproved                Boolean   @default(false)
  isVisible                 Boolean   @default(true)
  overallExperience         String?
  overallExperienceApproved Boolean   @default(false)
  programs                  String[]
  programsApproved          Boolean   @default(false)
  schedulingRating          Int?
  schedulingRatingApproved  Boolean   @default(false)
  school                    String?
  studentName               String?
  studentRating             Int?
  studentRatingApproved     Boolean   @default(false)
  submittedAt               DateTime?
  successStory              String?
  successStoryApproved      Boolean   @default(false)
  suggestions               String?
  updatedAt                 DateTime
  wouldRecommend            String?

  @@index([createdAt])
  @@index([parentId])
}

model ContactSubmission {
  id               Int      @id @default(autoincrement())
  fullName         String
  email            String
  phone            String?
  role             String?
  programInterest  String?
  subject          String
  message          String
  preferredContact String?
  studentName      String?
  studentGrade     String?
  status           String   @default("new")
  source           String   @default("contact_page")
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

model ParentAccount {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  phone       String?
  password    String?
  isActivated Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  students    Student[]
}

model TransactionReceipt {
  id              Int       @id @default(autoincrement())
  parentId        Int
  parentName      String
  parentEmail     String
  amount          String
  transactionDate String
  transactionId   String?
  description     String?
  receiptUrl      String
  receiptFileName String
  receiptFileSize Int
  status          String    @default("pending")
  adminNotes      String?
  createdAt       DateTime  @default(now())
  reviewedAt      DateTime?

  @@index([createdAt])
  @@index([parentId])
  @@index([status])
}

model Mentor {
  id           Int      @id @default(autoincrement())
  teacherId    Int?     @unique
  name         String
  role         String
  workplace    String
  education    String
  institution  String
  image        String
  experience   String?
  specialties  String[]
  achievements String[]
  bio          String
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  department   String   @default("General")
  teacher      Teacher? @relation(fields: [teacherId], references: [id])

  @@index([isActive, displayOrder])
  @@index([teacherId])
}

model ProgressReport {
  id                 Int      @id @default(autoincrement())
  studentId          Int
  teacherId          Int
  reportDate         DateTime @default(now())
  overallProgress    String
  milestonesAchieved String?
  publications       String?
  nextSteps          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  attendanceRate     Float?
  classParticipation String?
  homeworkCompletion Float?
  improvementAreas   String?
  isVisible          Boolean  @default(true)
  parentNotes        String?
  progressRating     Int?
  recommendations    String?
  reportPeriod       String?
  skillsImproved     String?
  status             String   @default("draft")
  strengthsAreas     String?
  subject            String?
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher            Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([reportDate])
  @@index([status])
}

model GeneralEvent {
  id                     Int                 @id @default(autoincrement())
  title                  String
  description            String
  category               String
  eventDate              DateTime
  eventTime              String
  location               String
  image                  String?
  maxParticipants        Int?
  registrationDeadline   DateTime?
  status                 String              @default("upcoming")
  isPublished            Boolean             @default(false)
  isFeatured             Boolean             @default(false)
  targetAudience         String?
  requirements           String?
  agenda                 String?
  speakers               Json?
  tags                   String[]
  contactEmail           String?
  contactPhone           String?
  createdBy              String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  customFields           Json?
  earlyBirdDeadline      DateTime?
  earlyBirdFee           Float?
  publishedAt            DateTime?
  publishedBy            String?
  registrationFee        Float?              @default(0)
  registrationFormConfig Json?
  requiresPayment        Boolean             @default(false)
  registrations          EventRegistration[]

  @@index([eventDate])
  @@index([status])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([category])
}

model EventRegistration {
  id                   Int          @id @default(autoincrement())
  eventId              Int
  studentName          String
  studentEmail         String
  studentPhone         String?
  studentGrade         String?
  schoolName           String?
  parentName           String
  parentEmail          String
  parentPhone          String?
  registrationStatus   String       @default("pending")
  paymentStatus        String?      @default("pending")
  paymentAmount        Float?       @default(0)
  specialRequirements  String?
  howDidYouHear        String?
  notes                String?
  checkedInAt          DateTime?
  attendanceConfirmed  Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  adminNotes           String?
  certificateIssued    Boolean      @default(false)
  customFieldResponses Json?
  paymentMethod        String?
  transactionId        String?
  event                GeneralEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentEmail])
  @@index([eventId])
  @@index([studentEmail])
  @@index([parentEmail])
  @@index([registrationStatus])
  @@index([paymentStatus])
}

model AccessRequest {
  id         String   @id @default(cuid())
  name       String
  email      String
  createdAt  DateTime @default(now())
  approved   Boolean  @default(false)
  phone      String?
  reason     String?
  researchId String
  research   Research @relation(fields: [researchId], references: [id])
}

model Research {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  description      String?
  published        Boolean            @default(true)
  author           String?
  createdAt        DateTime
  pdfFilename      String?
  abstract         String?
  category         String?
  extractedAt      DateTime?
  extractedContent Json?
  extractionStatus String?
  grade            String?
  keywords         String[]
  school           String?
  studentId        Int?
  domain           String?
  accessRequests   AccessRequest[]
  PptConversionJob PptConversionJob[]
  Student          Student?           @relation(fields: [studentId], references: [id])
  slides           Slide[]
}

model Slide {
  id            String   @id @default(cuid())
  researchId    String
  order         Int
  imageFilename String
  research      Research @relation(fields: [researchId], references: [id])
}

model Blog {
  id               Int       @id @default(autoincrement())
  title            String
  abstract         String
  externalUrl      String
  studentId        Int?
  studentPhoto     String?
  publicationYear  Int
  publicationMonth Int
  isApproved       Boolean   @default(false)
  published        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  approvedAt       DateTime?
  Student          Student?  @relation(fields: [studentId], references: [id])

  @@index([publicationYear, publicationMonth])
  @@index([published])
  @@index([studentId])
}

model PptConversionJob {
  id                String   @id
  researchId        String
  cloudConvertJobId String   @unique
  status            String   @default("queued")
  totalSlides       Int?
  processedSlides   Int      @default(0)
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  Research          Research @relation(fields: [researchId], references: [id], onDelete: Cascade)

  @@index([researchId])
  @@index([status])
}
