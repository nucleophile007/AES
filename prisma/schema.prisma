generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WebinarRegistration {
  id            Int      @id @default(autoincrement())
  email         String
  parentName    String
  parentEmail   String
  parentPhone   String
  studentName   String
  grade         String
  schoolName    String
  program       String
  preferredTime String
  createdAt     DateTime @default(now())
  approved      Boolean  @default(false)
  adminEmail    String?
}

model AvailabilityDay {
  id         Int      @id @default(autoincrement())
  date       String
  times      Json
  program    String
  adminEmail String   @default("acharya.folsom@gmail.com")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, program, adminEmail])
}

model Teacher {
  id                Int                       @id @default(autoincrement())
  name              String
  email             String                    @unique
  password          String?
  programs          String[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  isActivated       Boolean                   @default(false)
  assignments       Assignment[]
  classSchedules    ClassSchedule[]
  mentorProfile     Mentor?
  progressReports   ProgressReport[]
  resources         Resource[]
  submissionRemarks StudentSubmissionRemark[]
  students          TeacherStudent[]
}

model Student {
  id                  Int                 @id @default(autoincrement())
  name                String
  email               String              @unique
  password            String?
  grade               String
  schoolName          String
  parentName          String
  parentEmail         String
  parentPhone         String
  program             String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  isActivated         Boolean             @default(false)
  parentAccountId     Int?
  assignedAssignments Assignment[]        @relation("AssignedAssignments")
  classSchedules      ClassSchedule[]
  enrollments         Enrollment[]
  Payment             Payment[]
  progressReports     ProgressReport[]
  parentAccount       ParentAccount?      @relation(fields: [parentAccountId], references: [id])
  assignedResources   StudentResource[]
  studentSubmissions  StudentSubmission[]
  submissions         Submission[]
  teacherLinks        TeacherStudent[]
  Testimonial         Testimonial[]
}

model TeacherStudent {
  id         Int      @id @default(autoincrement())
  teacherId  Int
  studentId  Int
  program    String
  assignedAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId, program])
}

model Assignment {
  id                  Int                  @id @default(autoincrement())
  title               String
  description         String
  instructions        String?
  program             String
  subject             String
  dueDate             DateTime
  totalPoints         Int                  @default(100)
  isActive            Boolean              @default(true)
  allowLateSubmission Boolean              @default(false)
  teacherId           Int                  @default(1)
  targetStudentId     Int?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  targetStudent       Student?             @relation("AssignedAssignments", fields: [targetStudentId], references: [id])
  teacher             Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  resources           AssignmentResource[]
  submissions         Submission[]
}

model Submission {
  id               Int        @id @default(autoincrement())
  studentId        Int
  assignmentId     Int
  content          String?
  fileUrl          String?
  fileName         String?
  fileSize         Int?
  submittedAt      DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt
  grade            Int?
  feedback         String?
  status           String     @default("submitted")
  submissionNumber Int        @default(1)
  assignment       Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student          Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
}

model Enrollment {
  id        Int       @id @default(autoincrement())
  studentId Int
  program   String
  subject   String
  startDate DateTime  @default(now())
  isActive  Boolean   @default(true)
  access    String    @default("unblocked")
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Payment   Payment[]

  @@unique([studentId, program, subject])
}

model Resource {
  id                 Int                  @id @default(autoincrement())
  title              String
  description        String?
  type               String
  fileUrl            String?
  linkUrl            String?
  fileName           String?
  fileSize           Int?
  program            String
  subject            String
  grade              String
  teacherId          Int
  isPublic           Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  assignmentLinks    AssignmentResource[]
  teacher            Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentAssignments StudentResource[]
}

model AssignmentResource {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  resourceId   Int
  isRequired   Boolean    @default(false)
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  resource     Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, resourceId])
}

model StudentResource {
  id         Int       @id @default(autoincrement())
  studentId  Int
  resourceId Int
  assignedAt DateTime  @default(now())
  viewedAt   DateTime?
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, resourceId])
}

model StudentSubmission {
  id             Int                       @id @default(autoincrement())
  studentId      Int
  title          String
  description    String?
  content        String?
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  submittedAt    DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  teacherIds     Int[]
  student        Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherRemarks StudentSubmissionRemark[]
}

model StudentSubmissionRemark {
  id                  Int               @id @default(autoincrement())
  studentSubmissionId Int
  teacherId           Int
  remark              String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  studentSubmission   StudentSubmission @relation(fields: [studentSubmissionId], references: [id], onDelete: Cascade)
  teacher             Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([studentSubmissionId, teacherId])
}

model Message {
  id            String    @id @default(uuid())
  senderId      Int
  senderRole    String
  recipientId   Int
  recipientRole String
  content       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isRead        Boolean   @default(false)
  readAt        DateTime?

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, isRead])
  @@index([createdAt(sort: Desc)])
}

model ClassSchedule {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  startTime   String
  endTime     String
  subject     String
  description String?
  location    String?
  meetingLink String?
  status      String   @default("upcoming")
  color       String?
  studentId   Int
  teacherId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
}

model ActivationRequest {
  id        Int      @id @default(autoincrement())
  email     String
  role      String
  token     String   @unique
  userId    Int
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, role])
}

model PasswordResetRequest {
  id        Int      @id @default(autoincrement())
  role      String
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, userId])
  @@index([expiresAt])
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Payment {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  studentId    Int
  studentEmail String
  studentName  String
  parentName   String
  parentEmail  String
  parentPhone  String
  program      String
  subject      String
  paymentInfo  String
  amount       String?
  dueDate      String
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  status       String     @default("pending")
  sentAt       DateTime   @default(now())
  paidAt       DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  Student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id                      Int       @id @default(autoincrement())
  studentId               Int?
  content                 String?
  authorType              String?
  authorName              String?
  isApproved              Boolean   @default(false)
  isVisible               Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  videoLink               String?
  beforeAfterExpectations String?
  consentToFeature        Boolean   @default(false)
  experienceDescription   String?
  grade                   String?
  programs                String[]
  rating                  Int?
  school                  String?
  studentInfo             String?
  studentName             String?
  submittedAt             DateTime?
  successStory            String?
  beforeAfterApproved     Boolean   @default(false)
  contentApproved         Boolean   @default(false)
  programsApproved        Boolean   @default(false)
  ratingApproved          Boolean   @default(false)
  successStoryApproved    Boolean   @default(false)
  Student                 Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model SecurityLog {
  id        Int      @id @default(autoincrement())
  event     String
  userId    Int
  userRole  String
  success   Boolean
  ipAddress String
  userAgent String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, event])
  @@index([createdAt])
}

model FailedActivation {
  id        Int      @id @default(autoincrement())
  token     String
  ipAddress String
  userAgent String
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([ipAddress])
  @@index([createdAt])
}

model Feedback {
  id                        Int       @id @default(autoincrement())
  parentId                  Int?
  parentName                String?
  parentEmail               String?
  status                    String    @default("new")
  response                  String?
  createdAt                 DateTime  @default(now())
  reviewedAt                DateTime?
  beforeAfterApproved       Boolean   @default(false)
  beforeAfterExpectations   String?
  childExperience           String?
  childExperienceApproved   Boolean   @default(false)
  consentToFeature          Boolean   @default(false)
  favoriteThingToShare      String?
  grade                     String?
  heardAbout                String?
  isApproved                Boolean   @default(false)
  isVisible                 Boolean   @default(true)
  overallExperience         String?
  overallExperienceApproved Boolean   @default(false)
  programs                  String[]
  programsApproved          Boolean   @default(false)
  schedulingRating          Int?
  schedulingRatingApproved  Boolean   @default(false)
  school                    String?
  studentName               String?
  studentRating             Int?
  studentRatingApproved     Boolean   @default(false)
  submittedAt               DateTime?
  successStory              String?
  successStoryApproved      Boolean   @default(false)
  suggestions               String?
  updatedAt                 DateTime
  wouldRecommend            String?

  @@index([createdAt])
  @@index([parentId])
}

model ParentAccount {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  phone       String?
  password    String?
  isActivated Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  students    Student[]
}

model TransactionReceipt {
  id              Int       @id @default(autoincrement())
  parentId        Int
  parentName      String
  parentEmail     String
  amount          String
  transactionDate String
  transactionId   String?
  description     String?
  receiptUrl      String
  receiptFileName String
  receiptFileSize Int
  status          String    @default("pending")
  adminNotes      String?
  createdAt       DateTime  @default(now())
  reviewedAt      DateTime?

  @@index([createdAt])
  @@index([parentId])
  @@index([status])
}

model Mentor {
  id           Int      @id @default(autoincrement())
  teacherId    Int?     @unique
  name         String
  role         String
  workplace    String
  education    String
  institution  String
  image        String
  experience   String?
  specialties  String[]
  achievements String[]
  bio          String
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  department   String   @default("General")
  teacher      Teacher? @relation(fields: [teacherId], references: [id])
  
  @@index([isActive, displayOrder])
  @@index([teacherId])
}

model ProgressReport {
  id           Int      @id @default(autoincrement())
  studentId    Int
  teacherId    Int
  reportDate   DateTime @default(now())
  reportPeriod String? // e.g., "January 2026", "Q1 2026", "Week 1-4"
  subject      String? // Subject/Program area

  // Academic Progress
  overallProgress String // Overall summary/description
  progressRating  Int? // 1-5 or 1-10 rating scale
  attendanceRate  Float? // Percentage (0-100)

  // Achievements & Milestones
  milestonesAchieved String? // JSON array of milestones
  publications       String? // JSON array of publications/work
  skillsImproved     String? // JSON array of skills developed

  // Performance Areas (JSON for flexibility)
  strengthsAreas   String? // What student excels at
  improvementAreas String? // Areas needing attention

  // Goals & Planning
  nextSteps       String? // JSON array of next objectives
  recommendations String? // Teacher's recommendations
  parentNotes     String? // Notes specifically for parents

  // Engagement & Behavior
  classParticipation String? // Notes on participation
  homeworkCompletion Float? // Percentage (0-100)

  // Visibility & Status
  isVisible Boolean @default(true) // Can student/parent see this?
  status    String  @default("draft") // draft, published, archived

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([reportDate])
  @@index([status])
}

model GeneralEvent {
  id                   Int       @id @default(autoincrement())
  title                String
  description          String    @db.Text
  category             String // Workshop, Seminar, Webinar, Bootcamp, etc.
  eventDate            DateTime
  eventTime            String // e.g., "10:00 AM - 12:00 PM"
  location             String // Online (Zoom), AES Center, etc.
  image                String? // URL or path to event image
  maxParticipants      Int? // Maximum number of participants (null = unlimited)
  registrationDeadline DateTime? // Last date to register
  status               String    @default("upcoming") // upcoming, ongoing, completed, cancelled
  isPublished          Boolean   @default(false) // Publish to main website
  isFeatured           Boolean   @default(false) // Show on homepage carousel

  // Additional details
  targetAudience String? // Who should attend
  requirements   String?  @db.Text // Prerequisites or requirements
  agenda         String?  @db.Text // Event agenda/schedule
  speakers       Json? // Array of speaker details
  tags           String[] // For categorization and search

  // Registration Form Configuration (Admin decides which fields are required)
  registrationFormConfig Json? // JSON object defining required/optional fields
  // Example: { "studentPhone": "optional", "studentGrade": "required", "schoolName": "optional", "parentPhone": "required", "specialRequirements": "hidden" }
  customFields           Json? // Admin can add custom fields specific to this event
  // Example: [{ "name": "tshirtSize", "label": "T-Shirt Size", "type": "select", "options": ["S", "M", "L", "XL"], "required": true }]

  // Payment & Pricing
  registrationFee    Float?  @default(0) // Event registration fee
  earlyBirdFee       Float? // Early bird pricing
  earlyBirdDeadline  DateTime? // Early bird deadline
  requiresPayment    Boolean @default(false)
  
  // Contact & Admin
  contactEmail String?
  contactPhone String?
  createdBy    String? // Admin email who created the event
  publishedBy  String? // Admin who published it
  publishedAt  DateTime? // When it was published

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations EventRegistration[]

  @@index([eventDate])
  @@index([status])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([category])
}

model EventRegistration {
  id      Int @id @default(autoincrement())
  eventId Int

  // Core Registrant Information (always collected)
  studentName  String
  studentEmail String
  
  // Optional/Configurable Fields (based on event's registrationFormConfig)
  studentPhone String?
  studentGrade String?
  schoolName   String?

  // Parent/Guardian Information
  parentName  String
  parentEmail String
  parentPhone String?

  // Custom Field Responses (based on event's customFields)
  customFieldResponses Json? // Stores answers to custom questions
  // Example: { "tshirtSize": "M", "dietaryRestrictions": "Vegetarian", "emergencyContact": "555-1234" }

  // Registration Details
  registrationStatus String  @default("pending") // pending, registered, confirmed, cancelled, waitlist, attended, no-show
  paymentStatus      String? @default("pending") // pending, paid, refunded, waived, failed
  paymentAmount      Float?  @default(0)
  paymentMethod      String? // card, cash, bank_transfer, waived
  transactionId      String? // Payment gateway transaction ID

  // Additional fields
  specialRequirements String? @db.Text // Dietary restrictions, accessibility needs, etc.
  howDidYouHear       String? // Marketing tracking
  notes               String? @db.Text // Admin notes
  adminNotes          String? @db.Text // Private admin notes

  // Attendance tracking
  checkedInAt         DateTime?
  attendanceConfirmed Boolean   @default(false)
  certificateIssued   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event GeneralEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentEmail]) // Prevent duplicate registrations
  @@index([eventId])
  @@index([studentEmail])
  @@index([parentEmail])
  @@index([registrationStatus])
  @@index([paymentStatus])
}